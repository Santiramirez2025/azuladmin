# ============================================================================
# AZUL COLCHONES — variables de entorno
# Copiá este archivo a .env y completá los valores. NUNCA commitees .env real.
# ============================================================================

# Database (PostgreSQL — Neon / Supabase / etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# Supabase (cliente público — NEXT_PUBLIC_* viaja al browser)
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[ANON_KEY]"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ----------------------------------------------------------------------------
# Autenticación de admin
# ----------------------------------------------------------------------------
# Generar AUTH_SECRET (mínimo 32 bytes):
#   openssl rand -base64 48
AUTH_SECRET=""

AUTH_USERNAME="admin"

# Generar AUTH_PASSWORD_HASH:
#   npx ts-node scripts/hash-password.ts 'tu-password'
# Pegá la línea AUTH_PASSWORD_HASH=... que imprime el script.
AUTH_PASSWORD_HASH=""

# ----------------------------------------------------------------------------
# Operaciones destructivas (/api/seed, /api/products/clear)
# ----------------------------------------------------------------------------
# Generar:
#   openssl rand -hex 32
# Por defecto los endpoints destructivos están bloqueados en producción.
# Para habilitarlos en producción (NO recomendado), poner ALLOW_DESTRUCTIVE_OPS=true.
ADMIN_SETUP_SECRET=""
# ALLOW_DESTRUCTIVE_OPS="false"
